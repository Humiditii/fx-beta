# App
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=fx_trading

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=supersecretjwtsecret
JWT_EXPIRES_IN=7d

# Gmail SMTP
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
EMAIL_FROM_NAME=FX Trading App

# FX Rate API (https://www.exchangerate-api.com - free tier)
FX_API_KEY=your_exchangerate_api_key
FX_API_BASE_URL=https://v6.exchangerate-api.com/v6

# Swagger basic auth protection
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin123

# Service Name
SERVICE_NAME=fx-trading-service
